@startuml
!theme plain
skinparam linetype ortho
skinparam ranksep 60
skinparam nodesep 40

entity users {
  * id : bigint <<PK>>
  --
  * first_name : character varying
  * last_name : character varying
  * email : character varying <<UQ>>
  * password_hash : character varying
  * created_at : timestamp without time zone
  * role : character varying = 'admin'
}

entity telegram_subscriptions {
  * id : bigint <<PK>>
  --
  * telegram_chat_id : bigint
  * entity_type : character varying
  * entity_id : bigint
  * created_at : timestamp without time zone
}

entity academic_years {
  * id : bigint <<PK>>
  --
  * name : character varying
  * starts_at : date
  * ends_at : date
}

entity semesters {
  * id : bigint <<PK>>
  --
  * academic_year_id : bigint <<FK>>
  * number : integer
  * starts_at : date
  * ends_at : date
  * first_week_parity : smallint
}

entity groups {
  * id : bigint <<PK>>
  --
  * name : character varying
  * speciality : character varying
  * course : integer
  * student_count : integer
}

entity teachers {
  * id : bigint <<PK>>
  --
  * first_name : character varying
  * last_name : character varying
  * department : character varying
}

entity teacher_unavailability {
  * id : bigint <<PK>>
  --
  * teacher_id : bigint <<FK>>
  * day_of_week : smallint
  * unavailable_from : time without time zone
  * unavailable_to : time without time zone
}

entity subjects {
  * id : bigint <<PK>>
  --
  * name : character varying
}

entity teacher_subjects {
  * id : bigint <<PK>>
  --
  * teacher_id : bigint <<FK>>
  * subject_id : bigint <<FK>>
}

entity teaching_loads {
  * id : bigint <<PK>>
  --
  * semester_id : bigint <<FK>>
  * group_id : bigint <<FK>>
  * subject_id : bigint <<FK>>
  * teacher_id : bigint <<FK>>
  * lesson_type : smallint
  * required_lesson_count : integer
  * created_at : timestamp without time zone
  * updated_at : timestamp without time zone
  deleted_at : timestamp without time zone
  * requires_computer_room : boolean = false
}

entity rooms {
  * id : bigint <<PK>>
  --
  * name : character varying
  * type : character varying <<CHECK lecture|computer>>
  * capacity : integer
}

entity time_slots {
  * id : bigint <<PK>>
  --
  * number : integer
  * starts_at : time without time zone
  * ends_at : time without time zone
}

entity schedules {
  * id : bigint <<PK>>
  --
  * semester_id : bigint <<FK>>
  * status : character varying
  * valid_from : date
  * valid_to : date
  * created_by : bigint <<FK>>
  * created_at : timestamp without time zone
  published_at : timestamp without time zone
}

entity schedule_generation_jobs {
  * id : character varying(36) <<PK>>
  --
  * semester_id : bigint <<FK>>
  * requested_by : bigint <<FK>>
  * status : character varying
  generated_schedule_id : bigint <<FK>>
  quality_score : integer
  quality_status : character varying(32)
  error_message : text
  diagnostics : json
  * created_at : timestamp without time zone
  started_at : timestamp without time zone
  finished_at : timestamp without time zone
}

entity exam_schedule_generation_jobs {
  * id : character varying(36) <<PK>>
  --
  * semester_id : bigint <<FK>>
  * requested_by : bigint <<FK>>
  * status : character varying
  generated_exam_schedule_id : bigint <<FK>>
  quality_score : integer
  quality_status : character varying(32)
  error_message : text
  diagnostics : json
  * created_at : timestamp without time zone
  started_at : timestamp without time zone
  finished_at : timestamp without time zone
}

entity schedule_entries {
  * id : bigint <<PK>>
  --
  * schedule_id : bigint <<FK>>
  * subject_id : bigint <<FK>>
  * teacher_id : bigint <<FK>>
  * lesson_type : smallint
  * room_id : bigint <<FK>>
  * time_slot_id : bigint <<FK>>
  * day_of_week : smallint
  * week_parity : smallint
}

entity schedule_entry_groups {
  * schedule_entry_id : bigint <<FK>>
  * group_id : bigint <<FK>>
}

entity schedule_entry_teaching_loads {
  * schedule_entry_id : bigint <<FK>>
  * teaching_load_id : bigint <<FK>>
}

entity lessons {
  * id : bigint <<PK>>
  --
  schedule_entry_id : bigint <<FK>>
  * lesson_date : date
  * subject_id : bigint <<FK>>
  * teacher_id : bigint <<FK>>
  * lesson_type : smallint
  * room_id : bigint <<FK>>
  * time_slot_id : bigint <<FK>>
  * is_cancelled : boolean
  * is_override : boolean
}

entity lesson_groups {
  * lesson_id : bigint <<FK>>
  * group_id : bigint <<FK>>
}

entity exam_schedules {
  * id : bigint <<PK>>
  --
  * semester_id : bigint <<FK>>
  * status : smallint
  * created_by : bigint <<FK>>
  * created_at : timestamp without time zone
  published_at : timestamp without time zone
  deleted_at : timestamp without time zone
}

entity exam_schedule_entries {
  * id : bigint <<PK>>
  --
  * exam_schedule_id : bigint <<FK>>
  * type : smallint
  * subject_id : bigint <<FK>>
  * teacher_id : bigint <<FK>>
  * room_id : bigint <<FK>>
  * entry_date : date
  * starts_at : time without time zone
  deleted_at : timestamp without time zone
}

entity exam_schedule_entry_groups {
  * exam_schedule_entry_id : bigint <<FK>>
  * group_id : bigint <<FK>>
}

entity action_log {
  * id : bigint <<PK>>
  --
  * user_id : bigint <<FK>>
  * action : character varying
  * entity_type : character varying
  * entity_id : bigint
  * created_at : timestamp without time zone
  before_payload : json
  after_payload : json
}

users ||--o{ action_log : "створює"
users ||--o{ exam_schedules : "створює"
users ||--o{ schedules : "створює"
users ||--o{ schedule_generation_jobs : "запускає"
users ||--o{ exam_schedule_generation_jobs : "запускає"

academic_years ||--o{ semesters : "містить"

semesters ||--o{ schedules : "містить"
semesters ||--o{ exam_schedules : "містить"
semesters ||--o{ teaching_loads : "визначає навантаження"
semesters ||--o{ schedule_generation_jobs : "має задачі генерації"
semesters ||--o{ exam_schedule_generation_jobs : "має задачі генерації іспитів"

schedules ||--o{ schedule_entries : "містить"
schedules ||--o{ schedule_generation_jobs : "створюється задачею"

teachers ||--o{ teacher_unavailability : "має"
teachers ||--o{ teacher_subjects : "має"
teachers ||--o{ teaching_loads : "виконує навантаження"
teachers ||--o{ schedule_entries : "веде"
teachers ||--o{ lessons : "веде"
teachers ||--o{ exam_schedule_entries : "проводить"

subjects ||--o{ teacher_subjects : "має"
subjects ||--o{ teaching_loads : "має навантаження"
subjects ||--o{ schedule_entries : "входить до"
subjects ||--o{ lessons : "входить до"
subjects ||--o{ exam_schedule_entries : "входить до"

rooms ||--o{ schedule_entries : "використовується"
rooms ||--o{ lessons : "використовується"
rooms ||--o{ exam_schedule_entries : "використовується"

time_slots ||--o{ schedule_entries : "визначає час"
time_slots ||--o{ lessons : "визначає час"

schedule_entries ||--o{ schedule_entry_groups : "охоплює групи"
schedule_entries ||--o{ schedule_entry_teaching_loads : "виконує навантаження"
schedule_entries ||--o{ lessons : "породжує"

teaching_loads ||--o{ schedule_entry_teaching_loads : "виконується записами"

lessons ||--o{ lesson_groups : "охоплює групи"

groups ||--o{ schedule_entry_groups : "входить до"
groups ||--o{ lesson_groups : "входить до"
groups ||--o{ exam_schedule_entry_groups : "входить до"
groups ||--o{ teaching_loads : "має навантаження"

exam_schedules ||--o{ exam_schedule_entries : "містить"
exam_schedules ||--o{ exam_schedule_generation_jobs : "створюється задачею"
exam_schedule_entries ||--o{ exam_schedule_entry_groups : "охоплює групи"

@enduml
