# EditorConfig is awesome: https://EditorConfig.org
root = true

# Top-level defaults
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go files (backend)
[*.go]
indent_style = tab
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# JSON, YAML, Markdown, TOML, etc.
[*.{json,yml,yaml,md,toml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = true

# Next.js/JavaScript/TypeScript (frontend)
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Ignore minified files
[*.min.js]
indent_style = none
trim_trailing_whitespace = false
insert_final_newline = false

# Ignore build output
[build/*]
trim_trailing_whitespace = false
insert_final_newline = false

# Ignore node_modules
[node_modules/**]
trim_trailing_whitespace = false
insert_final_newline = false
